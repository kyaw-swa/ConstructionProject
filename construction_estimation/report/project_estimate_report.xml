<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_project_estimate_bq" model="ir.actions.report">
        <field name="name">Bill of Quantities (Summary)</field>
        <field name="model">construction.project.estimate</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">construction_estimation.report_project_estimate_bq_document</field>
        <field name="report_file">construction_estimation.report_project_estimate_bq_document</field>
        <field name="binding_model_id" ref="model_construction_project_estimate"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_project_estimate_bq_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-set="bq" t-value="doc.get_bq_summary()"/>
                    <div class="page">
                        <h2 class="text-center">Bill Of Quantity</h2>
                        <div class="row mb-3">
                            <div class="col-6">
                                <strong>Estimate:</strong>
                                <span t-field="doc.name"/>
                            </div>
                            <div class="col-3">
                                <strong>Customer:</strong>
                                <span t-field="doc.customer_id"/>
                            </div>
                            <div class="col-3">
                                <strong>Date:</strong>
                                <span t-field="doc.date"/>
                            </div>
                        </div>

                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr class="table-light">
                                    <th class="text-center" style="width:6%;">No</th>
                                    <th style="width:40%;">Particular</th>
                                    <th class="text-end" style="width:12%;">Quantity</th>
                                    <th class="text-center" style="width:8%;">Unit</th>
                                    <th class="text-end" style="width:12%;">Rate</th>
                                    <th class="text-end" style="width:7%;">Per</th>
                                    <th class="text-end" style="width:15%;">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="table-secondary">
                                    <td/>
                                    <td colspan="6"><strong>Material</strong></td>
                                </tr>
                                <t t-set="midx" t-value="0"/>
                                <t t-foreach="bq['materials']" t-as="row">
                                    <t t-set="midx" t-value="midx + 1"/>
                                    <tr>
                                        <td class="text-center" t-esc="midx"/>
                                        <td t-esc="row['name']"/>
                                        <td class="text-end">
                                            <span t-esc="'%.2f' % row['total_qty']"/>
                                        </td>
                                        <td class="text-center" t-esc="row['uom']"/>
                                        <td class="text-end">
                                            <span t-esc="'%.2f' % row['rate']"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-esc="'%.2f' % row['per']"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-esc="'%.2f' % row['total_amount']"/>
                                        </td>
                                    </tr>
                                </t>
                                <tr>
                                    <td colspan="6" class="text-end">
                                        <strong>Total Cost of Materials</strong>
                                    </td>
                                    <td class="text-end">
                                        <strong t-esc="'%.2f' % bq['material_subtotal']"/>
                                    </td>
                                </tr>

                                <tr class="table-secondary">
                                    <td/>
                                    <td colspan="6"><strong>Labour</strong></td>
                                </tr>
                                <t t-set="lidx" t-value="0"/>
                                <t t-foreach="bq['labours']" t-as="row">
                                    <t t-set="lidx" t-value="lidx + 1"/>
                                    <tr>
                                        <td class="text-center" t-esc="lidx"/>
                                        <td t-esc="row['name']"/>
                                        <td class="text-end">
                                            <span t-esc="'%.2f' % row['total_qty']"/>
                                        </td>
                                        <td class="text-center" t-esc="row['uom']"/>
                                        <td class="text-end">
                                            <span t-esc="'%.2f' % row['rate']"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-esc="'%.2f' % row['per']"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-esc="'%.2f' % row['total_amount']"/>
                                        </td>
                                    </tr>
                                </t>
                                <tr>
                                    <td colspan="6" class="text-end">
                                        <strong>Total Cost of Labours</strong>
                                    </td>
                                    <td class="text-end">
                                        <strong t-esc="'%.2f' % bq['labour_subtotal']"/>
                                    </td>
                                </tr>

                                <tr class="table-warning">
                                    <td colspan="6" class="text-end">
                                        <strong>Grand Total (Mat + Lab)</strong>
                                    </td>
                                    <td class="text-end">
                                        <strong t-esc="'%.2f' % bq['grand_total']"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <t t-if="doc.notes">
                            <h4 class="mt-4">Notes</h4>
                            <p t-field="doc.notes"/>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>


</odoo>
