<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_construction_material_list" model="ir.ui.view">
        <field name="name">construction.material.list</field>
        <field name="model">construction.material</field>
        <field name="arch" type="xml">
            <list string="Materials" editable="bottom">
                <field name="name"/>
                <field name="uom_id" string="UOM"/>
                <field name="default_rate" string="Default Rate"/>
            </list>
        </field>
    </record>

    <record id="view_construction_material_kanban" model="ir.ui.view">
        <field name="name">construction.material.kanban</field>
        <field name="model">construction.material</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="uom_id"/>
                <field name="default_rate"/>
                <field name="active"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex align-items-start justify-content-between gap-2">
                            <div>
                                <strong class="d-block fs-5">
                                    <field name="name"/>
                                </strong>
                                <span class="text-muted">
                                    <field name="uom_id"/>
                                </span>
                            </div>
                            <field name="active" widget="boolean_toggle"/>
                        </div>
                        <div class="mt-3">
                            <span class="text-muted">Default Rate</span>
                            <div class="fw-bold">
                                <field name="default_rate"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_construction_material_form" model="ir.ui.view">
        <field name="name">construction.material.form</field>
        <field name="model">construction.material</field>
        <field name="arch" type="xml">
            <form string="Material">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="uom_id" string="Unit of Measure"/>
                        </group>
                        <group>
                            <field name="default_rate"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_construction_material" model="ir.actions.act_window">
        <field name="name">Materials</field>
        <field name="res_model">construction.material</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

</odoo>
