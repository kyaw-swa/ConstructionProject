<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_construction_measurement_list" model="ir.ui.view">
        <field name="name">construction.measurement.list</field>
        <field name="model">construction.measurement</field>
        <field name="arch" type="xml">
            <list string="Measurements">
                <field name="ac_id"/>
                <field name="name" string="Type"/>
                <field name="parent_id" string="Parent"/>
                <field name="description"/>
                <field name="sequence" widget="handle"/>
            </list>
        </field>
    </record>

    <record id="view_construction_measurement_form" model="ir.ui.view">
        <field name="name">construction.measurement.form</field>
        <field name="model">construction.measurement</field>
        <field name="arch" type="xml">
            <form string="Measurement Type">
                <sheet>
                    <group>
                        <group>
                            <field name="ac_id"/>
                            <field name="name" string="Type (e.g. F1, RW1)"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="parent_id" domain="[('ac_id','=',ac_id)]"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Sub-Measurements">
                            <field name="child_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="sequence" widget="handle"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_construction_measurement" model="ir.actions.act_window">
        <field name="name">Measurements</field>
        <field name="res_model">construction.measurement</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
