<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Kanban View -->
    <record id="view_construction_project_kanban" model="ir.ui.view">
        <field name="name">construction.project.kanban</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="color"/>
                <field name="currency_id"/>
                <progressbar field="state"
                             colors='{"draft": "muted", "in_progress": "info", "on_hold": "warning", "done": "success", "cancelled": "danger"}'/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record_top mb-2">
                            <div class="o_kanban_record_headings">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <small class="o_kanban_record_subtitle text-muted">
                                    <field name="code"/>
                                </small>
                            </div>
                            <field name="state" widget="label_selection"
                                   options="{'classes': {'draft': 'secondary', 'in_progress': 'info', 'on_hold': 'warning', 'done': 'success', 'cancelled': 'danger'}}"/>
                        </div>
                        <div class="o_kanban_record_body">
                            <field name="partner_id"/>
                        </div>
                        <div class="o_kanban_record_bottom">
                            <div class="oe_kanban_bottom_left">
                                <span class="me-2">Income: <field name="total_income" widget="monetary"/></span>
                                <span class="me-2">Expense: <field name="total_expense" widget="monetary"/></span>
                            </div>
                            <div class="oe_kanban_bottom_right">
                                <span class="me-2">Cash: <field name="cash_position" widget="monetary"/></span>
                            </div>
                        </div>
                        <div class="o_kanban_record_bottom">
                            <div class="oe_kanban_bottom_left">
                                <span>Budget used: <field name="budget_used_percent" widget="percentage"/></span>
                            </div>
                            <div class="oe_kanban_bottom_right">
                                <span><field name="transaction_count"/> transactions</span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_construction_project_form" model="ir.ui.view">
        <field name="name">construction.project.form</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_set_in_progress" type="object" string="Start"
                            class="oe_highlight" invisible="state not in ('draft', 'on_hold')"/>
                    <button name="action_set_on_hold" type="object" string="Hold"
                            invisible="state != 'in_progress'"/>
                    <button name="action_set_done" type="object" string="Done"
                            class="oe_highlight" invisible="state not in ('in_progress', 'on_hold')"/>
                    <button name="action_set_cancelled" type="object" string="Cancel"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_set_draft" type="object" string="Reset to Draft"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_progress,on_hold,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_transactions" type="object"
                                class="oe_stat_button" icon="fa-exchange">
                            <field name="transaction_count" widget="statinfo" string="Transactions"/>
                        </button>
                    </div>
                    <field name="currency_id" invisible="1"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Project Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="partner_id"/>
                            <field name="project_manager_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="state"/>
                            <field name="currency_id"/>
                        </group>
                    </group>
                    <group string="Totals">
                        <group>
                            <field name="planned_budget" widget="monetary"/>
                            <field name="total_income" widget="monetary"/>
                            <field name="total_expense" widget="monetary"/>
                        </group>
                        <group>
                            <field name="committed_expense" widget="monetary"/>
                            <field name="cash_position" widget="monetary"/>
                            <field name="budget_used_percent" widget="percentage"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Transactions" name="transactions">
                            <field name="transaction_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="txn_type"/>
                                    <field name="name"/>
                                    <field name="cost_category_id"/>
                                    <field name="paid_by_id"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="amount" widget="monetary"/>
                                </list>
                            </field>
                        </page>
                        <page string="Budget" name="budget">
                            <field name="budget_line_ids">
                                <list editable="bottom">
                                    <field name="cost_category_id"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="budget_amount" widget="monetary"/>
                                    <field name="committed_amount" widget="monetary"/>
                                    <field name="actual_amount" widget="monetary"/>
                                    <field name="variance" widget="monetary"/>
                                    <field name="variance_pct" widget="percentage"/>
                                </list>
                            </field>
                        </page>
                        <page string="Cash Advances" name="cash_advances">
                            <field name="advance_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="cash_holder_id"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="amount_advanced" widget="monetary"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_construction_project_list" model="ir.ui.view">
        <field name="name">construction.project.list</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="start_date"/>
                <field name="state"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="planned_budget" widget="monetary"/>
                <field name="total_income" widget="monetary"/>
                <field name="total_expense" widget="monetary"/>
                <field name="cash_position" widget="monetary"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_construction_project_search" model="ir.ui.view">
        <field name="name">construction.project.search</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="partner_id"/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
                <filter name="filter_on_hold" string="On Hold" domain="[('state', '=', 'on_hold')]"/>
                <filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>
                <filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
                <group>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_manager" string="Project Manager" context="{'group_by': 'project_manager_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_construction_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">construction.project</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_construction_project_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first construction project
            </p>
        </field>
    </record>

</odoo>
